      <method name="to_matrix"
              c:identifier="hkl_quaternion_to_matrix"
              shadowed-by="to_matrix_binding">
        <doc xml:space="preserve"
             filename="hkl/hkl-quaternion.c"
             line="231">Compute the rotation matrix of a Quaternion.

compute the rotation matrix corresponding to the unitary quaternion.
\f$ q = a + b \cdot i + c \cdot j + d \cdot k \f$

\f$
\left(
 \begin{array}{ccc}
   a^2+b^2-c^2-d^2 &amp; 2bc-2ad         &amp; 2ac+2bd\\
   2ad+2bc         &amp; a^2-b^2+c^2-d^2 &amp; 2cd-2ab\\
   2bd-2ac         &amp; 2ab+2cd         &amp; a^2-b^2-c^2+d^2
 \end{array}
\right)
\f$
Todo: optimize</doc>
        <source-position filename="hkl.h" line="128"/>
        <return-value transfer-ownership="none">
          <type name="none" c:type="void"/>
        </return-value>
        <parameters>
          <instance-parameter name="self" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="hkl/hkl-quaternion.c"
                 line="233">the #HklQuaternion use to compute the #HklMatrix</doc>
            <type name="Quaternion" c:type="const HklQuaternion*"/>
          </instance-parameter>
          <parameter name="m"
                     direction="out"
                     caller-allocates="1"
                     transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="hkl/hkl-quaternion.c"
                 line="234">the #HklMatrix return.</doc>
            <type name="Matrix" c:type="HklMatrix*"/>
          </parameter>
        </parameters>
      </method>
      <method name="to_matrix_binding"
              c:identifier="hkl_quaternion_to_matrix_binding"
              shadows="to_matrix">

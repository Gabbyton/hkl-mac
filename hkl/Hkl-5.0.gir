    <record name="Quaternion"
            c:type="HklQuaternion"
            glib:type-name="HklQuaternion"
            glib:get-type="hkl_quaternion_get_type"
            c:symbol-prefix="quaternion">
      <source-position filename="hkl.h" line="124"/>
